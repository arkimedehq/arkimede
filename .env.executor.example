# ──────────────────────────────────────────────────────────────────────────────
# .env.executor (ROOT) — EXECUTOR config for LOCAL execution (non-Docker).
#
#   cp .env.executor.example .env.executor
#
# Read by executor/src/env.ts (single source for the executor when run locally).
# In Docker it is NOT used: compose passes the variables in the environment: block
# of the skill-executor service (interpolating SKILL_*/SERVICE_API_KEY from .env).
#
# Env convention (all at the root, distinct names):
#   .env            → backend
#   .env.executor   → executor (this file)
#   frontend/.env   → frontend (VITE_*, Vite convention, stays in frontend/)
# embedding/whisper have no .env: they are configured from docker-compose.
# ──────────────────────────────────────────────────────────────────────────────

# Port/host of the executor process (do NOT use 3000: it belongs to the backend).
PORT=4000
HOST=127.0.0.1

# Paths shared with the backend — SAME absolute values as UPLOAD_DIR/skills and
# UPLOAD_DIR/skills-output in the backend's .env.
SKILLS_BASE_PATH=/absolute/path/to/backend/uploads/skills
SKILLS_OUTPUT_DIR=/absolute/path/to/backend/uploads/skills-output

# Skill execution limits.
MAX_TIMEOUT_MS=30000
MAX_OUTPUT_BYTES=524288
MAX_CONCURRENT=5
JS_MEMORY_LIMIT_MB=128
INSTALL_TIMEOUT_MS=300000

# Sandbox (run_in_sandbox tool) — DEVELOPMENT only.
# Without a broker (BROKER_URL not set) the sandbox is fail-closed and REFUSES to run.
# Set to 1 to run arbitrary code IN-PROCESS in the executor: NOT isolated
# (full host access, host network) — use it only to try out logic locally, NEVER in
# production. In production the isolation is provided by the broker (container-job).
SANDBOX_ALLOW_INPROCESS=0

# GC of the sandbox session workspaces (per-chat). Removes those inactive for
# more than SANDBOX_SESSION_TTL_MS; runs every SANDBOX_GC_INTERVAL_MS (default 24h / 1h).
SANDBOX_SESSION_TTL_MS=86400000
SANDBOX_GC_INTERVAL_MS=3600000
# Disk quota per session workspace: above this threshold /sandbox refuses (0 = off). Default 500MB.
SANDBOX_SESSION_MAX_BYTES=524288000
# Maximum timeout of a sandbox execution (ms). Higher than the skill default because
# runtime installs (pip/uvx/npm) download packages and easily exceed 30s. Default 120s.
SANDBOX_TIMEOUT_MS=120000

# Backend URL for the scripts' internal APIs (locally: localhost).
BACKEND_INTERNAL_URL=http://localhost:3000

# Backend↔executor mesh auth (x-service-key header). It MUST match EXACTLY
# SERVICE_API_KEY in the backend's .env, otherwise the executor rejects the
# requests (fail-closed). Generate once with `openssl rand -hex 32` and paste
# the SAME value into both files.
SERVICE_API_KEY=
