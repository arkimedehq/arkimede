{
  "name": "arkimede-cli",
  "version": "0.1.0",
  "description": "Arkimede terminal client — login and chat with your self-hosted AI agents from the shell (TUI + scriptable REPL)",
  "license": "AGPL-3.0-or-later",
  "author": "Andrea Genovese",
  "homepage": "https://github.com/arkimedehq/arkimede/blob/main/docs/CLI.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkimedehq/arkimede.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/arkimedehq/arkimede/issues"
  },
  "keywords": [
    "arkimede",
    "ai",
    "agents",
    "cli",
    "tui",
    "terminal",
    "chat",
    "self-hosted",
    "llm"
  ],
  "type": "module",
  "bin": {
    "arkimede": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.31",
    "typescript": "^5.5.4"
  }
}
