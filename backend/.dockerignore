# User data and vendored skill dependencies: they must NEVER end up in the build
# context nor in the image layers (they bloat the build and are runtime data).
uploads/

# Dependencies and artifacts: reinstalled/rebuilt inside the image.
node_modules/
dist/
coverage/

# Local secrets: they never go into an image.
.env
.env.*
!.env.example

# Miscellaneous noise.
*.log
.git
.gitignore
test/
.vscode/
