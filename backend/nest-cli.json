{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "tsc",
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger/plugin"],
    "assets": [{ "include": "i18n/**/*.json", "watchAssets": true }]
  },
  "watchAssets": true
}
