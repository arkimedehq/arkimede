{
  "name": "arkimede-backend",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "description": "Arkimede — NestJS Backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "NODE_OPTIONS=--openssl-legacy-provider node dist/main",
    "start:dev": "NODE_OPTIONS=--openssl-legacy-provider nest start --watch",
    "start:debug": "NODE_OPTIONS=--openssl-legacy-provider nest start --debug --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run test/unit",
    "test:watch": "vitest test/unit",
    "test:int": "vitest run test/integration --no-file-parallelism",
    "test:security": "vitest run security.spec",
    "test:cov": "vitest run test/unit --coverage",
    "test:all": "npm run test && npm run test:int",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/data-source.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.7",
    "@marsaud/smb2": "^0.18.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/serve-static": "^4.0.1",
    "@nestjs/swagger": "^7.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/websockets": "^10.4.22",
    "@qdrant/js-client-rest": "^1.9.0",
    "adm-zip": "^0.5.17",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.10.1",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docx": "^9.7.1",
    "dotenv": "^16.4.5",
    "helmet": "^7.2.0",
    "ioredis": "^5.11.1",
    "ipaddr.js": "^1.9.1",
    "js-yaml": "^4.1.1",
    "langchain": "^1.4.2",
    "mammoth": "^1.7.2",
    "mongodb": "^7.3.0",
    "mssql": "^12.5.5",
    "multer": "^2.2.0",
    "mysql2": "^3.22.3",
    "nestjs-i18n": "^10.6.1",
    "ntlm": "file:./vendor/ntlm",
    "openai": "^6.39.0",
    "oracledb": "^7.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "puppeteer": "^22.4.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "ssh2-sftp-client": "^11.0.0",
    "swagger-ui-express": "^5.0.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1",
    "voyageai": "^0.2.1",
    "webdav": "^5.7.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@swc/core": "^1.4.11",
    "@testcontainers/postgresql": "^12.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/mssql": "^12.3.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "ntlm": "file:./vendor/ntlm"
  }
}
