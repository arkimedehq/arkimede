# ──────────────────────────────────────────────────────────────────────────────
# frontend/.env — FRONTEND config (Vite).
#
#   cp frontend/.env.example frontend/.env
#
# Stays HERE (not at the root) for two reasons: it is the Vite convention, and this
# file goes into the bundle served to the BROWSER. Only public `VITE_*` variables
# belong here: NEVER backend secrets (they would end up in the client). Secrets live
# in the root .env.
# ──────────────────────────────────────────────────────────────────────────────

# App name shown in the UI.
VITE_APP_NAME=Arkimede

# Base URL of the NestJS backend (without /api).
# LEAVE EMPTY: the frontend uses the Vite proxy (relative /api), so it works both from
# localhost and from other devices on the LAN (http://<ip-mac>:5173). Setting it to an
# absolute URL (e.g. http://localhost:3000) BREAKS remote access, because "localhost"
# on the remote device points to itself, not to the Mac.
VITE_BACKEND_URL=
VITE_API_URL=

# WebSocket URL (Electron bridge / notifications).
# Empty → derived from window.location (same host as the frontend), works on the LAN too.
VITE_WS_URL=

# GitHub repo (owner/name) that hosts the desktop "bridge" releases. The "Download
# bridge" button in Settings → MCP Servers points at its latest release (dmg/exe/
# AppImage published by .github/workflows/release-bridge.yml). Set this to the public
# repo before release. Empty → defaults to the current git remote.
VITE_BRIDGE_REPO=
